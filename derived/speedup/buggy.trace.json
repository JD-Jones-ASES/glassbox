{
  "id": "speedup-dependent",
  "title": "Parallel speedup — a chain you can't parallelize",
  "problem": "Run four tasks on two workers and measure the speedup over running them one at a time.",
  "register": "naive",
  "language": "python",
  "derivation_source": "execution-derived",
  "domain_model": "author-asserted-simulation",
  "provenance": {
    "language": "python",
    "trace_source": "sys.settrace",
    "tracer_version": "0.1.0",
    "author": "GlassBox",
    "created": "2026-06-25"
  },
  "abstraction": {
    "type": "gantt",
    "label": "Two workers, a dependency chain",
    "bind": {
      "lanes": "lanes",
      "speedup": "speedup",
      "sequential_time": "sequential_time",
      "parallel_time": "parallel_time"
    }
  },
  "source": "tasks = [[\"A\", 3], [\"B\", 2], [\"C\", 2], [\"D\", 1]]\nlanes = [[], []]\nclock = 0\ni = 0\nfor task in tasks:\n    w = i % 2\n    start = clock\n    end = start + task[1]\n    lanes[w].append([task[0], start, end])\n    clock = end\n    i = i + 1\nsequential_time = 0\nfor task in tasks:\n    sequential_time = sequential_time + task[1]\nparallel_time = clock\nspeedup = sequential_time / parallel_time\n",
