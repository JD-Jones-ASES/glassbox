  "source": "pixels = [\"W\", \"W\", \"W\", \"B\", \"B\", \"W\"]\nout = []\nrun_char = pixels[0]\nrun_len = 1\nfor p in pixels[1:]:\n    if p == run_char:\n        run_len = run_len + 1\n    else:\n        out.append([run_len, run_char])\n        run_char = p\n        run_len = 1\nout.append([run_len, run_char])\n",
