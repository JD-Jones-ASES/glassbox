  "source": "network = {\"A\": [\"B\", \"C\"], \"B\": [\"A\", \"D\"], \"C\": [\"A\", \"D\"], \"D\": [\"B\", \"C\"]}\nroutes = [[\"A\", \"B\", \"C\", \"D\"], [\"A\", \"C\", \"D\"], [\"A\", \"B\", \"D\"]]\nat = [\"A\", \"A\", \"A\"]\npos = [0, 0, 0]\narrived = []\nwhile len(arrived) < 3:\n    for p in range(3):\n        if pos[p] < len(routes[p]) - 1:\n            pos[p] = pos[p] + 1\n            at[p] = routes[p][pos[p]]\n            if at[p] == \"D\" and p not in arrived:\n                arrived.append(p)\nmessage = sorted(arrived)\n",
