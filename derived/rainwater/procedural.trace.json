  "source": "heights = [3, 0, 2, 0, 4]\nn = len(heights)\nleft = [0] * n\nright = [0] * n\nm = 0\nfor i in range(n):\n    if heights[i] > m:\n        m = heights[i]\n    left[i] = m\nm = 0\nfor i in range(n - 1, -1, -1):\n    if heights[i] > m:\n        m = heights[i]\n    right[i] = m\nwater = [0] * n\ntotal = 0\nfor i in range(n):\n    fill = min(left[i], right[i]) - heights[i]\n    if fill > 0:\n        water[i] = fill\n        total = total + fill\n",
