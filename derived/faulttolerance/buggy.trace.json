  "source": "network = {\"A\": [\"B\"], \"B\": [\"A\", \"D\"], \"D\": [\"B\"]}\ndown = [\"B\"]\nat = \"A\"\npath = [at]\nwhile at != \"D\":\n    moved = False\n    for nxt in network[at]:\n        if nxt not in down and nxt not in path:\n            at = nxt\n            path.append(at)\n            moved = True\n            break\n    if not moved:\n        break\n",
