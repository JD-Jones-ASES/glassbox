  "id": "faulttolerance-redundant",
  "title": "Fault tolerance — rerouting around a dead node",
  "problem": "Send a packet from A to D after node B fails. A redundant network should find another way.",
  "register": "procedural",
  "language": "python",
  "derivation_source": "execution-derived",
  "domain_model": "author-asserted-simulation",
