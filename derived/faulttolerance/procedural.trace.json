      "at": "current",
      "path": "path",
      "down": "down"
    }
  },
  "source": "network = {\"A\": [\"B\", \"C\"], \"B\": [\"A\", \"D\"], \"C\": [\"A\", \"D\"], \"D\": [\"B\", \"C\"]}\ndown = [\"B\"]\nat = \"A\"\npath = [at]\nwhile at != \"D\":\n    moved = False\n    for nxt in network[at]:\n        if nxt not in down and nxt not in path:\n            at = nxt\n            path.append(at)\n            moved = True\n            break\n    if not moved:\n        break\n",
