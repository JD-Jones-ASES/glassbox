{
  "name": "glassbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:preview": "set LOCAL_ROOT=1&& astro dev --port 4321",
    "build": "astro build",
    "preview": "astro preview",
    "trace": "uv --project tracer run trace-lessons",
    "validate:traces": "node scripts/validate/validate-traces.mjs",
    "validate:scan": "node scripts/validate/scan-text.mjs",
    "prepare:traces": "npm run trace && npm run validate:traces && npm run validate:scan"
  },
  "dependencies": {
    "@astrojs/svelte": "^9.0.0",
    "astro": "^7.0.0",
    "svelte": "^5.56.3"
  },
  "devDependencies": {
    "@fontsource-variable/space-grotesk": "^5.2.5",
    "@fontsource/ibm-plex-mono": "^5.2.5",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  }
}
