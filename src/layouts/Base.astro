---
import "@fontsource-variable/space-grotesk";
import "@fontsource/ibm-plex-mono";
import "../styles/portal.css";
import { withBase } from "../lib/withBase.js";

const { title = "GlassBox", description = "Watch code actually run." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={withBase("favicon.svg")} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={withBase("/")}>Glass<span class="dot">▸</span>Box</a>
      <span class="tagline">watch code actually run</span>
      <nav class="site-nav">
        <a href={withBase("/lessons/")}>Lessons</a>
        <a href={withBase("/glossary/")}>Glossary</a>
        <a href={withBase("/verification/")}>Verification</a>
      </nav>
    </header>
    <main class="shell">
      <slot />
    </main>
    <footer class="site-footer">
      <p>
        GlassBox — a from-first-principles look at how computers actually work.
        Code <a href="https://opensource.org/license/mit">MIT</a>;
        content <a href="https://creativecommons.org/licenses/by-sa/4.0/">CC BY-SA 4.0</a>. AI-authored
        under an owner-designed verification system.
      </p>
    </footer>

    <script>
      // Site-wide glossary popup. Event-delegated on the document, so it covers static prose AND anything
      // the Svelte player renders — any element with data-term gets a hover/focus quick definition.
      import { termsMap } from "../lib/glossary.js";

      let popup;
      function ensurePopup() {
        if (!popup) {
          popup = document.createElement("div");
          popup.className = "term-popup";
          popup.setAttribute("role", "tooltip");
          document.body.appendChild(popup);
        }
        return popup;
      }
      function show(el) {
        const def = termsMap[el.dataset.term];
        if (!def) return;
        const p = ensurePopup();
        p.innerHTML = "";
        const h = document.createElement("strong");
        h.textContent = def.term;
        const d = document.createElement("span");
        d.textContent = def.short;
        p.append(h, d);
        p.style.display = "block";
        const r = el.getBoundingClientRect();
        const vw = document.documentElement.clientWidth;
        const vh = document.documentElement.clientHeight;
        const pw = p.offsetWidth, ph = p.offsetHeight;
        let left = Math.max(8, Math.min(r.left, vw - pw - 8)) + window.scrollX;
        let top = r.bottom + 6;
        if (top + ph > vh && r.top - 6 - ph > 0) top = r.top - ph - 6; // flip above if no room below
        p.style.left = left + "px";
        p.style.top = top + window.scrollY + "px";
      }
      function hide() { if (popup) popup.style.display = "none"; }

      document.addEventListener("mouseover", (e) => { const el = e.target.closest("[data-term]"); if (el) show(el); });
      document.addEventListener("mouseout", (e) => { const el = e.target.closest("[data-term]"); if (el && !el.contains(e.relatedTarget)) hide(); });
      document.addEventListener("focusin", (e) => { const el = e.target.closest("[data-term]"); if (el) show(el); });
      document.addEventListener("focusout", (e) => { const el = e.target.closest("[data-term]"); if (el) hide(); });
      document.addEventListener("keydown", (e) => { if (e.key === "Escape") hide(); });
      window.addEventListener("scroll", hide, true);
    </script>
  </body>
</html>
