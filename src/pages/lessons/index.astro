---
import Base from "../../layouts/Base.astro";
import { withBase } from "../../lib/withBase.js";
import { modules, flatLessons } from "../../lib/curriculum.js";

// The catalog is now a course OUTLINE driven by the curriculum manifest (src/lib/curriculum.js) — one
// ordered path instead of a flat card grid. Module order = the course arc; the step number on each row is
// the continuous course index. Editorial titles/blurbs live in the manifest, the single source of truth.
const courseIndexBySlug = Object.fromEntries(flatLessons().map((l) => [l.slug, l.courseIndex]));
---

<Base title="Lessons — GlassBox" description="A step-by-step course: watch small programs run, one line at a time.">
  <h1>The course</h1>
  <p class="lede">
    One path, in order. Each lesson is a small program you step through, watching the state change line by
    line — and most ship with the buggy version a beginner writes, watched failing. Start at the top, or
    jump to whatever you came for.
  </p>

  {modules.map((m, mi) => (
    <section class="module">
      <h2><span class="mod-num">{mi + 1}</span>{m.name}</h2>
      <p class="module-blurb">{m.blurb}</p>
      <ol class="steps">
        {m.lessons.map((l) => (
          <li class="step">
            <span class="step-num">{courseIndexBySlug[l.slug]}</span>
            <a class="step-link" href={withBase(`/lessons/${l.slug}/`)}>
              <span class="step-head">
                <span class="step-title">{l.title}</span>
                {l.milestone && (
                  <span class="badge milestone"><span class="led"></span>milestone</span>
                )}
                {l.kind === "author-asserted-simulation" && (
                  <span class="badge asserted"><span class="led"></span>simulation</span>
                )}
              </span>
              <span class="step-blurb">{l.blurb}</span>
            </a>
          </li>
        ))}
      </ol>
    </section>
  ))}
</Base>

<style>
  .module { margin-top: 1.8rem; }
  .module h2 { display: flex; align-items: baseline; gap: 0.6rem; margin-bottom: 0.2rem; }
  .mod-num {
    font-family: var(--font-mono); font-size: 0.85rem; font-weight: 600; color: var(--live);
    border: 1px solid var(--border-strong); border-radius: var(--radius-sm);
    padding: 0.05rem 0.5rem; line-height: 1.4;
  }
  .module-blurb { color: var(--ink-faint); margin: 0 0 0.8rem; max-width: 64ch; }

  /* The stepped path: a connector line runs down the left, with each step's number sitting on it. */
  .steps {
    list-style: none; margin: 0; padding: 0 0 0 1.4rem;
    border-left: 2px solid var(--border); display: flex; flex-direction: column; gap: 0.7rem;
  }
  .step { position: relative; }
  .step-num {
    position: absolute; left: calc(-1.4rem - 1px); top: 0.9rem; transform: translateX(-50%);
    width: 1.6rem; height: 1.6rem; border-radius: 50%;
    display: grid; place-items: center;
    font-family: var(--font-mono); font-size: 0.78rem; font-weight: 600;
    color: var(--live-ink); background: var(--live-wash); border: 1px solid var(--live);
  }
  .step-link {
    display: flex; flex-direction: column; gap: 0.2rem;
    background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
    box-shadow: var(--shadow); padding: 0.75rem 1rem; text-decoration: none; color: var(--ink);
  }
  .step-link:hover { border-color: var(--live); }
  .step-head { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
  .step-title { font-family: var(--font-display); font-weight: 600; font-size: 1.05rem; }
  .step-blurb { color: var(--ink-soft); font-size: 0.92rem; }
</style>
