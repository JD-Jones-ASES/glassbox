---
import Base from "../../layouts/Base.astro";
import { withBase } from "../../lib/withBase.js";

// The lesson catalog. One entry per anchor; add a line as each lesson lands. (Could be generated from
// derived/ later, but the editorial titles/blurbs live here for now.)
const pillars = [
  {
    name: "Programs & State",
    blurb: "The small programs, traced line by line.",
    lessons: [
      {
        slug: "swap",
        title: "Swapping two values",
        blurb: "Three ways to swap two cups — including the one a beginner writes, watched failing.",
      },
      {
        slug: "partition",
        title: "Sorting into two piles",
        blurb: "Split numbers into evens and odds — and watch a one-character bug merge the piles.",
      },
      {
        slug: "accumulate",
        title: "Adding up a list",
        blurb: "Keep a running total — and watch the = vs += bug stop it from ever adding.",
      },
      {
        slug: "search",
        title: "Linear search",
        blurb: "Find where a value lives — and watch the index-vs-value mix-up return the wrong thing.",
      },
      {
        slug: "filter",
        title: "Filtering a list",
        blurb: "Keep the items that pass a test — and watch deleting-while-looping skip an element.",
      },
      {
        slug: "functions",
        title: "Functions: package an idea you can call",
        blurb: "The same job four ways — see a function open its own scope and hand a value back.",
      },
    ],
  },
  {
    name: "Data",
    blurb: "How computers represent information — every bit of it a program you can trace.",
    lessons: [
      {
        slug: "binary",
        title: "Decimal to binary",
        blurb: "Watch 13 fill the powers-of-two columns to become 1101 — place value, traced as real Python.",
      },
      {
        slug: "rle",
        title: "Run-length encoding",
        blurb: "Compress a row of pixels into (length, colour) pairs — and watch the bug that drops the last run.",
      },
      {
        slug: "bindecimal",
        title: "Binary to decimal",
        blurb: "Turn 1101 back into 13 by doubling — and watch the base mix-up read it as eleven hundred.",
      },
      {
        slug: "overflow",
        title: "Overflow",
        blurb: "Watch an 8-bit counter wrap 255 → 0 — and watch Python's unbounded ints refuse to.",
      },
      {
        slug: "roundoff",
        title: "Roundoff",
        blurb: "Watch 0.1 + 0.2 come out as 0.30000000000000004 — and why == is a trap on floats.",
      },
    ],
  },
  {
    name: "Systems & Networks",
    blurb: "How machines talk — modelled as small simulations and traced like any other program.",
    lessons: [
      {
        slug: "routing",
        title: "Packet switching",
        blurb: "Follow a packet hopping across a network graph from A to D, one hop at a time.",
      },
    ],
  },
];
---

<Base title="Lessons — GlassBox" description="Step through small programs and watch their state, line by line.">
  <h1>Lessons</h1>
  <p class="lede">
    Each lesson is a small program you step through, watching the state change one line at a time. Pick a
    register — including the buggy one — and let CPython, not a teacher, show you what really happens.
  </p>

  {pillars.map((p) => (
    <section class="pillar">
      <h2>{p.name}</h2>
      <p class="pillar-blurb">{p.blurb}</p>
      <ul class="lesson-list">
        {p.lessons.map((l) => (
          <li class="card">
            <a href={withBase(`/lessons/${l.slug}/`)}>
              <span class="lesson-title">{l.title}</span>
              <span class="lesson-blurb">{l.blurb}</span>
              <span class="go">Open →</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Base>

<style>
  .pillar { margin-top: 1.6rem; }
  .pillar-blurb { color: var(--ink-faint); margin: 0 0 0.8rem; }
  .lesson-list { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; }
  @media (max-width: 720px) { .lesson-list { grid-template-columns: 1fr; } }
  .lesson-list .card { padding: 0; }
  .lesson-list a {
    display: flex; flex-direction: column; gap: 0.3rem; padding: 1rem 1.1rem; text-decoration: none;
    color: var(--ink); height: 100%;
  }
  .lesson-title { font-family: var(--font-display); font-weight: 600; font-size: 1.1rem; }
  .lesson-blurb { color: var(--ink-soft); font-size: 0.92rem; }
  .go { margin-top: auto; color: var(--live); font-size: 0.85rem; font-weight: 600; }
  .lesson-list a:hover .go { text-decoration: underline; }
</style>
